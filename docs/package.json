{
  "name": "acontext-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:cf": "opennextjs-cloudflare build && node scripts/patch-worker.mjs",
    "preview": "pnpm build:cf && opennextjs-cloudflare preview",
    "deploy": "pnpm build:cf && opennextjs-cloudflare deploy",
    "upload": "pnpm build:cf && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.182",
    "@next/third-parties": "^16.2.6",
    "@opennextjs/cloudflare": "^1.19.9",
    "@radix-ui/react-hover-card": "^1.1.15",
    "ai": "^6.0.180",
    "d3-force": "^3.0.0",
    "fumadocs-core": "16.8.10",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-openapi": "^10.8.2",
    "fumadocs-ui": "16.8.10",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3-force": "^3.0.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0"
    }
  }
}
